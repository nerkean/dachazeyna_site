<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('partials/head', { title: 'Дача Зейна | Bee Swarm Simulator' }) %>
        
    <link rel="preload" href="/css/style.css" as="style">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <main>
        <section class="hero-section">
            <div class="hero-bg-grid"></div>
            <div class="hero-ambient-glow glow-left"></div>
            <div class="hero-ambient-glow glow-right"></div>

            <div class="hero-decor-wrapper">
    <div class="decor-item decor-1">
        <div class="decor-icon di-gold"><i class="fas fa-coins"></i></div>
        <div class="decor-text">
            <span>Экономика</span>
            Уникальный бот
        </div>
    </div>
    <div class="decor-item decor-2">
        <div class="decor-icon di-purple"><i class="fas fa-trophy"></i></div>
        <div class="decor-text">
            <span>Ивенты</span>
            Турниры и раздачи
        </div>
    </div>
    <div class="decor-item decor-3">
        <div class="decor-icon di-green"><i class="fas fa-leaf"></i></div>
        <div class="decor-text">
