    <!-- ЛОГИКА АНИМАЦИЙ GSAP -->
    <script nonce="<%= locals.nonce %>">
        document.addEventListener('DOMContentLoaded', () => {
            gsap.registerPlugin(ScrollTrigger);

            const heroTl = gsap.timeline();
            heroTl.fromTo(".b-hero-badge", {y: -20, opacity: 0}, {y: 0, opacity: 1, duration: 0.6, ease: "back.out(1.7)"})
                  .fromTo(".b-hero-title", {y: 30, opacity: 0}, {y: 0, opacity: 1, duration: 0.8, ease: "power3.out"}, "-=0.4")
                  .fromTo(".b-hero-desc", {y: 30, opacity: 0}, {y: 0, opacity: 1, duration: 0.8, ease: "power3.out"}, "-=0.6")
                  .fromTo(".b-hero-actions", {y: 20, opacity: 0}, {y: 0, opacity: 1, duration: 0.6, ease: "power2.out"}, "-=0.5")
                  .fromTo(".b-hero-visual", {x: 50, opacity: 0, rotationY: 15}, {x: 0, opacity: 1, rotationY: 0, duration: 1, ease: "power3.out"}, "-=0.8");

            gsap.utils.toArray('.gs-fade-up').forEach(element => {
                gsap.fromTo(element, 
                    { y: 50, opacity: 0 },
                    { scrollTrigger: { trigger: element, start: "top 85%" }, y: 0, opacity: 1, duration: 0.8, ease: "power3.out" }
                );
            });

            gsap.fromTo(".b-pass-text", { x: -50, opacity: 0 }, { scrollTrigger: { trigger: ".b-pass-section", start: "top 75%" }, x: 0, opacity: 1, duration: 0.8, ease: "power3.out" });
            gsap.fromTo(".b-pass-ui", { x: 50, opacity: 0 }, { scrollTrigger: { trigger: ".b-pass-section", start: "top 75%" }, x: 0, opacity: 1, duration: 0.8, ease: "power3.out", delay: 0.2 });
            
            gsap.fromTo(".b-profile-visual", { x: 50, opacity: 0, rotationY: 15 }, { scrollTrigger: { trigger: ".b-profile-section", start: "top 75%" }, x: 0, opacity: 1, rotationY: 0, duration: 1, ease: "back.out(1.2)" });
            gsap.fromTo(".gs-stagger-profile li", { x: -30, opacity: 0 }, { scrollTrigger: { trigger: ".gs-stagger-profile", start: "top 80%" }, x: 0, opacity: 1, duration: 0.6, stagger: 0.15, ease: "power2.out" });

            gsap.fromTo(".b-marriage-visual", { x: 50, opacity: 0, rotationY: 15 }, { scrollTrigger: { trigger: ".b-marriage-section", start: "top 75%" }, x: 0, opacity: 1, rotationY: 0, duration: 1, ease: "back.out(1.2)" });
            gsap.fromTo(".gs-stagger-marriage li", { x: -30, opacity: 0 }, { scrollTrigger: { trigger: ".gs-stagger-marriage", start: "top 80%" }, x: 0, opacity: 1, duration: 0.6, stagger: 0.15, ease: "power2.out" });
            
            gsap.fromTo(".eco-orbit-wrapper", { scale: 0.8, opacity: 0 }, { scrollTrigger: { trigger: ".b-economy-section", start: "top 75%" }, scale: 1, opacity: 1, duration: 1, ease: "back.out(1.2)" });
            
            gsap.fromTo(".b-craft-visual", { x: -50, opacity: 0, rotationY: -15 }, { scrollTrigger: { trigger: ".b-craft-section", start: "top 75%" }, x: 0, opacity: 1, rotationY: 8, duration: 1, ease: "back.out(1.2)" });
            gsap.fromTo(".gs-stagger-craft li", { x: 30, opacity: 0 }, { scrollTrigger: { trigger: ".gs-stagger-craft", start: "top 80%" }, x: 0, opacity: 1, duration: 0.6, stagger: 0.15, ease: "power2.out" });

            gsap.fromTo(".quest-terminal", { x: 50, opacity: 0, rotationY: 15 }, { scrollTrigger: { trigger: ".b-quests-section", start: "top 75%" }, x: 0, opacity: 1, rotationY: -5, duration: 1, ease: "back.out(1.2)" });
            gsap.fromTo(".gs-stagger-quests li", { x: -30, opacity: 0 }, { scrollTrigger: { trigger: ".gs-stagger-quests", start: "top 80%" }, x: 0, opacity: 1, duration: 0.6, stagger: 0.15, ease: "power2.out" });

            gsap.fromTo(".b-minigames-visual", { x: -50, opacity: 0, rotationY: -15 }, { scrollTrigger: { trigger: ".b-minigames-section", start: "top 75%" }, x: 0, opacity: 1, rotationY: 0, duration: 1, ease: "back.out(1.2)" });
            gsap.fromTo(".gs-stagger-games li", { x: 30, opacity: 0 }, { scrollTrigger: { trigger: ".gs-stagger-games", start: "top 80%" }, x: 0, opacity: 1, duration: 0.6, stagger: 0.15, ease: "power2.out" });
            
            gsap.fromTo(".gs-tier", { y: 60, opacity: 0 }, { scrollTrigger: { trigger: ".b-patreon-section", start: "top 70%" }, y: 0, opacity: 1, duration: 0.8, stagger: 0.2, ease: "back.out(1.2)" });
            gsap.fromTo(".gs-bento", { scale: 0.9, opacity: 0, y: 30 }, { scrollTrigger: { trigger: ".b-features-section", start: "top 70%" }, scale: 1, opacity: 1, y: 0, duration: 0.7, stagger: 0.15, ease: "power3.out" });

            gsap.to(".orb-1", { scrollTrigger: { trigger: "body", start: "top top", end: "bottom bottom", scrub: true }, y: 200, ease: "none" });
            gsap.to(".orb-2", { scrollTrigger: { trigger: "body", start: "top top", end: "bottom bottom", scrub: true }, y: -200, ease: "none" });
        });

        document.addEventListener('DOMContentLoaded', () => {
            const btnCraft = document.getElementById('btn-craft');
            if(btnCraft) {
                btnCraft.addEventListener('click', () => {
                    if(btnCraft.disabled) return;
                    btnCraft.disabled = true;
                    btnCraft.innerHTML = '<i class="fas fa-cog fa-spin"></i> Синтез...';
                    
                    const slot1 = document.getElementById('craft-slot-1');
                    const slot2 = document.getElementById('craft-slot-2');
                    const slot3 = document.getElementById('craft-slot-3');
                    const resultSlot = document.getElementById('craft-result');
                    const resultItem = document.getElementById('result-item');
                    
                    gsap.to([slot1, slot2, slot3], { x: () => Math.random() * 6 - 3, y: () => Math.random() * 6 - 3, duration: 0.1, yoyo: true, repeat: 15 });
                    
                    setTimeout(() => {
                        gsap.to([slot1, slot2, slot3], { scale: 0, opacity: 0, duration: 0.3 });
                        
                        setTimeout(() => {
                            resultSlot.classList.add('crafted');
                            gsap.to(resultItem, { opacity: 1, scale: 1.5, duration: 0.5, ease: "back.out(2)" });
                            gsap.to(".craft-glow", { opacity: 1, duration: 0.3 });
                            
                            btnCraft.innerHTML = '<i class="fas fa-check"></i> Успех!';
                            
                            setTimeout(() => {
                                resultSlot.classList.remove('crafted');
                                gsap.to(resultItem, { opacity: 0, scale: 1, duration: 0.3 });
                                gsap.to(".craft-glow", { opacity: 0, duration: 0.3 });
                                gsap.to([slot1, slot2, slot3], { scale: 1, opacity: 1, duration: 0.5, ease: "back.out(1.5)" });
                                
                                btnCraft.disabled = false;
                                btnCraft.innerHTML = '<i class="fas fa-magic"></i> Запустить синтез';
                            }, 3000);
                        }, 300);
                    }, 1500);
                });
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            const bgAssets = <%- JSON.stringify(locals.bgAssets ? locals.bgAssets : [
                '/assets/backgrounds/halloween_pumpkins.webp',
                '/assets/backgrounds/legend.webp',
                '/assets/backgrounds/premium_card_bg_galaxy.webp',
                '/assets/backgrounds/stars_dark.webp'
            ]) %>;
            
            const frameAssets = <%- JSON.stringify(locals.frameAssets ? locals.frameAssets : [
                '/assets/frames/avatar_frame_azure_spark.webp',
                '/assets/frames/halloween_web.webp',
                '/assets/frames/laurel_blue.webp',
                '/assets/frames/patterned_bronze.webp',
                '/assets/frames/premium_avatar_frame_gold_plated.webp',
                '/assets/frames/veteran.webp'
            ]) %>;

            const btnProfile = document.getElementById('btn-random-profile');
            const cardBg = document.getElementById('p-card-bg') || document.querySelector('.p-card-bg');
            const cardFrame = document.getElementById('p-avatar-frame') || document.querySelector('.p-avatar-frame');

            function setRandomProfile() {
                if (!bgAssets.length || !frameAssets.length) return;
                const randomBg = bgAssets[Math.floor(Math.random() * bgAssets.length)];
                const randomFrame = frameAssets[Math.floor(Math.random() * frameAssets.length)];
                if (cardBg) cardBg.style.backgroundImage = `url('${randomBg}')`;
                if (cardFrame) {
                    cardFrame.src = randomFrame;
                    cardFrame.style.opacity = '1';
                }
            }

            setRandomProfile();

            if(btnProfile && cardBg && cardFrame) {
                btnProfile.addEventListener('click', () => {
                    const icon = btnProfile.querySelector('i');
                    if(icon) icon.classList.add('fa-spin');

                    gsap.fromTo("#interactive-profile",
                        { scale: 0.96, opacity: 0.8, filter: "brightness(1.5) contrast(1.2)" },
                        { scale: 1, opacity: 1, filter: "brightness(1) contrast(1)", duration: 0.6, ease: "power2.out" }
                    );

                    setTimeout(() => {
                        setRandomProfile();
                        if(icon) icon.classList.remove('fa-spin');
                    }, 150);
                });
            }
        });

        document.addEventListener('DOMContentLoaded', () => {
            const container = document.getElementById('star-3d-canvas');
            if (!container) return;

            const scene = new THREE.Scene();
            const camera = new THREE.PerspectiveCamera(45, container.clientWidth / container.clientHeight, 0.1, 1000);
            camera.position.z = 6;

            const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: false });
            renderer.setSize(container.clientWidth, container.clientHeight);
            renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5)); 
            container.appendChild(renderer.domElement);

            const shape = new THREE.Shape();
            const outerRadius = 1.4;
            const innerRadius = 0.6;
            const spikes = 5;
            const rot = -Math.PI / 2;
            
            for (let i = 0; i < spikes * 2; i++) {
                const radius = i % 2 === 0 ? outerRadius : innerRadius;
                const angle = rot + (i * Math.PI) / spikes;
                const x = Math.cos(angle) * radius;
                const y = Math.sin(angle) * radius;
                if (i === 0) shape.moveTo(x, y);
                else shape.lineTo(x, y);
            }
            shape.closePath();

            const extrudeSettings = { depth: 0.2, bevelEnabled: true, bevelSegments: 1, steps: 1, bevelSize: 0.1, bevelThickness: 0.1 };
            const geometry = new THREE.ExtrudeGeometry(shape, extrudeSettings);
            geometry.center();

            const material = new THREE.MeshStandardMaterial({
                color: 0xffd700, emissive: 0xaa7700, emissiveIntensity: 0.3, metalness: 0.8, roughness: 0.15
            });
            const star = new THREE.Mesh(geometry, material);
            scene.add(star);

            const edges = new THREE.EdgesGeometry(geometry);
            const lineMat = new THREE.LineBasicMaterial({ color: 0xffffff, transparent: true, opacity: 0.3 });
            const wireframe = new THREE.LineSegments(edges, lineMat);
            star.add(wireframe);

            const particleGeo = new THREE.BufferGeometry();
            const particleCount = 70;
            const posArray = new Float32Array(particleCount * 3);
            for(let i=0; i < particleCount * 3; i++) posArray[i] = (Math.random() - 0.5) * 8;
            particleGeo.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
            const particleMat = new THREE.PointsMaterial({ size: 0.06, color: 0xffd700, transparent: true, opacity: 0.8, blending: THREE.AdditiveBlending });
            const particleMesh = new THREE.Points(particleGeo, particleMat);
            scene.add(particleMesh);

            const ambientLight = new THREE.AmbientLight(0xffffff, 0.4);
            scene.add(ambientLight);
            const pointLight1 = new THREE.PointLight(0xffffff, 1.5, 100);
            pointLight1.position.set(5, 5, 5);
            scene.add(pointLight1);
            const pointLight2 = new THREE.PointLight(0xffaa00, 2, 100);
            pointLight2.position.set(-5, -5, 2);
            scene.add(pointLight2);

            let clock = new THREE.Clock();

            function animate() {
                requestAnimationFrame(animate);
                const t = clock.getElapsedTime();
                star.rotation.y += 0.008;
                star.position.y = Math.sin(t * 1.5) * 0.15;
                particleMesh.rotation.y -= 0.002;
                particleMesh.rotation.x += 0.001;
                renderer.render(scene, camera);
            }
            animate();

            window.addEventListener('resize', () => {
                if(!container) return;
                camera.aspect = container.clientWidth / container.clientHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(container.clientWidth, container.clientHeight);
            });
        });

        document.addEventListener('DOMContentLoaded', () => {
            const allQuests = [
                { icon: "fa-comment-dots", title: "Социальная бабочка", desc: "Написать 100 сообщений в чатах", req: "0 / 100", reward: "+300 XP" },
                { icon: "fa-microphone", title: "Радиоведущий", desc: "Провести 1 час в голосовых каналах", req: "0 / 60 мин", reward: "+500 XP" },
                { icon: "fa-box-open", title: "Охотник за лутом", desc: "Открыть 10 любых кейсов", req: "0 / 10", reward: "+200 ⭐" },
                { icon: "fa-hammer", title: "Мастер на все руки", desc: "Скрафтить 50 предметов на верстаке", req: "0 / 50", reward: "+450 XP" },
                { icon: "fa-calendar-check", title: "Дисциплина", desc: "Забрать ежедневную награду (/daily)", req: "0 / 1", reward: "+100 ⭐" },
                { icon: "fa-dice", title: "Азартный игрок", desc: "Сыграть 5 раз в казино", req: "0 / 5", reward: "+150 XP" },
                { icon: "fa-ring", title: "Романтик", desc: "Отправить 5 поцелуев партнеру", req: "0 / 5", reward: "+100 XP" },
                { icon: "fa-gavel", title: "Спекулянт", desc: "Выставить 3 лота на аукцион", req: "0 / 3", reward: "+300 ⭐" }
            ];

            const container = document.getElementById('quest-container');
            const btn = document.getElementById('reroll-quests');
            const icon = document.getElementById('reroll-icon');

            function renderQuests(animate = false) {
                const shuffled = [...allQuests].sort(() => 0.5 - Math.random());
                const selected = shuffled.slice(0, 3);
                
                container.innerHTML = '';
                
                selected.forEach((q, index) => {
                    const randomPerc = Math.floor(Math.random() * 70); 
                    const card = document.createElement('div');
                    card.className = 'quest-card';
                    card.innerHTML = `
                        <div class="quest-icon"><i class="fas ${q.icon}"></i></div>
                        <div class="quest-info">
                            <div class="quest-title">${q.title}</div>
                            <div class="quest-desc">${q.desc}</div>
                            <div class="quest-progress-wrap">
                                <div class="q-bar-bg"><div class="q-bar-fill" style="width: 0%"></div></div>
                                <span class="q-req">${q.req}</span>
                            </div>
                        </div>
                        <div class="quest-reward">${q.reward}</div>
                    `;
                    container.appendChild(card);

                    if(animate) {
                        gsap.fromTo(card, { x: 30, opacity: 0 }, { x: 0, opacity: 1, duration: 0.4, delay: index * 0.1 });
                        setTimeout(() => { card.querySelector('.q-bar-fill').style.width = randomPerc + '%'; }, 500 + (index * 100));
                    } else {
                        card.querySelector('.q-bar-fill').style.width = randomPerc + '%';
                    }
                });
            }

            renderQuests();

            btn.addEventListener('click', () => {
                if(icon.classList.contains('fa-spin')) return;
                icon.classList.add('fa-spin');
                
                gsap.to(".quest-card", { 
                    x: -30, opacity: 0, duration: 0.3, stagger: 0.05, 
                    onComplete: () => {
                        renderQuests(true);
                        setTimeout(() => icon.classList.remove('fa-spin'), 1000);
                    }
                });
            });
        });
    </script>
</body>
</html>