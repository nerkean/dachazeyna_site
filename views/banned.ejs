<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('partials/head', { title: 'Доступ закрыт | Система безопасности' }) %>
    <style>
        :root {
            --danger: #ff0055;
            --danger-glow: rgba(255, 0, 85, 0.3);
            --danger-dim: rgba(255, 0, 85, 0.1);
            --warning: #ffb800;
            --warning-glow: rgba(255, 184, 0, 0.3);
            --warning-dim: rgba(255, 184, 0, 0.1);
            --bg-dark: #050608;
            --glass: rgba(15, 17, 26, 0.8);
        }

        body { 
            background: var(--bg-dark); 
            color: #fff; 
            font-family: 'Montserrat', sans-serif; 
            display: flex; 
            align-items: center; 
            justify-content: center; 
            min-height: 100vh; 
            margin: 0;
            overflow-x: hidden; 
        }

        .cyber-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            z-index: 0; pointer-events: none;
            background: radial-gradient(circle at center, #1a050a 0%, #050608 100%);
        }

        .bg-grid {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            background-image: 
                linear-gradient(rgba(255, 0, 85, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 0, 85, 0.03) 1px, transparent 1px);
            background-size: 50px 50px;
            animation: panGrid 20s linear infinite;
        }

        .danger-vignette {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            box-shadow: inset 0 0 150px rgba(255, 0, 85, 0.1);
        }

        .ban-wrapper {
            position: relative; z-index: 10;
            width: 100%; max-width: 650px;
            padding: 20px;
            box-sizing: border-box;
            animation: popIn 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        .ban-card { 
            background: var(--glass); 
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border: 1px solid rgba(255, 255, 255, 0.05); 
            border-top: 1px solid rgba(255, 0, 85, 0.3);
            border-radius: 32px; 
            padding: 50px 40px; 
            text-align: center;
            box-shadow: 0 30px 80px rgba(0, 0, 0, 0.8), 0 0 40px var(--danger-glow);
            position: relative;
            overflow: hidden;
        }

        .ban-card::after {
            content: ''; position: absolute; top: -50%; left: 0; width: 100%; height: 200%;
            background: linear-gradient(to bottom, transparent, rgba(255,0,85,0.05), transparent);
            animation: scanline 6s linear infinite;
            pointer-events: none;
        }

        .ban-icon { 
            display: inline-flex; align-items: center; justify-content: center;
            width: 100px; height: 100px;
            background: var(--danger-dim);
            border: 2px solid var(--danger);
            border-radius: 50%;
            font-size: 3.5rem; 
            color: var(--danger); 
            margin-bottom: 25px; 
            box-shadow: 0 0 30px var(--danger-glow);
            animation: pulseAlert 2s infinite; 
        }

        h1 { 
            font-size: 2.2rem; 
            font-weight: 900; 
            margin-bottom: 10px; 
            text-transform: uppercase; 
            letter-spacing: 2px; 
            color: #fff;
            text-shadow: 0 0 10px var(--danger-glow);
        }

        p.subtitle { 
            color: #9ca3af; 
            font-size: 1.05rem; 
            margin-bottom: 30px; 
            line-height: 1.6;
        }

        .ban-reason-box {
            text-align: left;
            background: rgba(0, 0, 0, 0.5);
            border-left: 4px solid var(--danger);
            padding: 15px 20px;
            border-radius: 8px;
            margin-bottom: 35px;
            position: relative;
        }
        .ban-reason-box::before {
            content: 'ПРИЧИНА:';
            display: block;
            color: var(--danger);
            font-size: 0.75rem;
            font-weight: 800;
            font-family: 'JetBrains Mono', monospace;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }
        .ban-reason-text {
            color: #e5e7eb;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.95rem;
            word-break: break-word;
        }

        .appeal-form { text-align: left; }

        .form-group { margin-bottom: 25px; }

        .form-label {
            display: block; color: #9ca3af;
            font-size: 0.8rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .form-input, .form-textarea {
            width: 100%;
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: #fff;
            padding: 15px;
            border-radius: 12px;
            font-family: inherit;
            font-size: 1rem;
            transition: all 0.3s ease;
            box-sizing: border-box; 
        }

        .form-input:focus, .form-textarea:focus {
            outline: none;
            border-color: var(--danger);
            background: rgba(255, 0, 85, 0.05);
            box-shadow: 0 0 20px var(--danger-dim);
        }

        .form-textarea { height: 120px; resize: vertical; }

        .btn-submit {
            width: 100%; background: var(--danger); color: #fff;
            padding: 16px; border: none; border-radius: 14px;
            font-weight: 800; font-size: 1rem; text-transform: uppercase;
            letter-spacing: 2px; cursor: pointer; transition: 0.3s;
            box-shadow: 0 10px 20px var(--danger-dim);
            display: flex; justify-content: center; align-items: center; gap: 10px;
        }
        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px var(--danger-glow);
            background: #ff1a66;
        }
        .btn-submit:disabled { opacity: 0.7; cursor: not-allowed; transform: none; }

        .pending-status {
            background: var(--warning-dim);
            border: 1px solid rgba(255, 184, 0, 0.3);
            padding: 30px 20px;
            border-radius: 20px;
            margin-bottom: 30px;
        }
        .pending-icon {
            font-size: 2.5rem; color: var(--warning);
            margin-bottom: 15px; animation: float 3s ease-in-out infinite;
        }
        .pending-status strong { display: block; color: var(--warning); font-size: 1.2rem; margin-bottom: 8px; }
        .pending-status span { color: #d1d5db; font-size: 0.95rem; }

        .rejected-status {
            background: var(--danger-dim);
            border: 1px solid rgba(255, 0, 85, 0.3);
            padding: 30px 20px;
            border-radius: 20px;
            margin-bottom: 30px;
        }
        .rejected-icon {
            font-size: 2.5rem; color: var(--danger);
            margin-bottom: 15px; 
            text-shadow: 0 0 15px var(--danger);
        }
        .rejected-status strong { display: block; color: var(--danger); font-size: 1.2rem; margin-bottom: 8px; text-transform: uppercase; }
        .rejected-status span { color: #d1d5db; font-size: 0.95rem; }

        .btn-logout { 
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(255,255,255,0.05); color: #9ca3af; 
            padding: 12px 25px; border-radius: 50px; 
            text-decoration: none; font-weight: 600; font-size: 0.9rem;
            border: 1px solid rgba(255,255,255,0.1); transition: 0.3s;
            margin-top: 15px;
        }
        .btn-logout:hover { background: rgba(255,255,255,0.1); color: #fff; border-color: rgba(255,255,255,0.2); }

        @keyframes popIn { 0% { opacity: 0; transform: scale(0.95) translateY(20px); } 100% { opacity: 1; transform: scale(1) translateY(0); } }
        @keyframes pulseAlert { 0%, 100% { box-shadow: 0 0 0 0 var(--danger-glow); } 50% { box-shadow: 0 0 0 20px rgba(255,0,85,0); } }
        @keyframes panGrid { 0% { background-position: 0 0; } 100% { background-position: 0 50px; } }
        @keyframes scanline { 0% { transform: translateY(-100%); } 100% { transform: translateY(100%); } }
        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

        @media (max-width: 600px) {
            .ban-card { padding: 40px 20px; }
            .ban-icon { width: 80px; height: 80px; font-size: 2.5rem; }
            h1 { font-size: 1.8rem; }
            .form-input, .form-textarea { font-size: 16px; }
        }
    </style>
</head>
<body>
    <div class="cyber-bg">
        <div class="bg-grid"></div>
        <div class="danger-vignette"></div>
    </div>

    <div class="ban-wrapper">
        <div class="ban-card">
            <div class="ban-icon"><i class="fas fa-user-lock"></i></div>
            
            <h1>Доступ Заблокирован</h1>
            <p class="subtitle">Ваш аккаунт был изолирован от сервера "Дача Зейна" в связи с нарушением пунктов правил.</p>
            
            <div class="ban-reason-box">
                <div class="ban-reason-text"><%= reason %></div>
            </div>

            <% if (typeof hasRejectedAppeal !== 'undefined' && hasRejectedAppeal) { %>
                <div class="rejected-status">
                    <i class="fas fa-ban rejected-icon"></i>
                    <strong>В апелляции отказано</strong>
                    <span>Администрация рассмотрела ваш запрос и приняла решение оставить блокировку в силе. <br>Дальнейшие апелляции невозможны.</span>
                </div>
            <% } else if (typeof hasPendingAppeal !== 'undefined' && hasPendingAppeal) { %>
                <div class="pending-status">
                    <i class="fas fa-hourglass-half pending-icon"></i>
                    <strong>Апелляция на рассмотрении</strong>
                    <span>Высший стафф уже получил ваш запрос. <br>Ожидайте вердикта администрации.</span>
                </div>
            <% } else { %>
                <form id="appealForm" class="appeal-form">
                    <div class="form-group">
                        <label class="form-label">Ваша версия (За что получили бан?)</label>
                        <input type="text" id="userReason" class="form-input" placeholder="Например: Я нарушил правило 1.4, потому что..." required minlength="5">
                    </div>

                    <div class="form-group">
                        <label class="form-label">Почему мы должны вас разбанить?</label>
                        <textarea id="userAppeal" class="form-textarea" placeholder="Я осознал свою ошибку и обещаю больше не..." required minlength="10"></textarea>
                    </div>

                    <button type="submit" class="btn-submit">
                        <i class="fas fa-paper-plane"></i> Отправить запрос
                    </button>
                </form>
            <% } %>

            <a href="/auth/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> Выйти из аккаунта</a>
        </div>
    </div>

    <script nonce="<%= nonce %>">
        const form = document.getElementById('appealForm');
        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                const userReason = document.getElementById('userReason').value;
                const userAppeal = document.getElementById('userAppeal').value;

                const combinedText = `[Причина бана со слов игрока]:\n${userReason}\n\n[Оправдание]:\n${userAppeal}`;
                
                const btn = form.querySelector('.btn-submit');
                const originalBtnText = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = "<i class='fas fa-spinner fa-spin'></i> Отправка...";

                try {
                    const res = await fetch('/api/appeal', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ text: combinedText })
                    });
                    const data = await res.json();
                    
                    if (data.success) {
                        btn.innerHTML = "<i class='fas fa-check'></i> Успешно";
                        btn.style.background = "#2ecc71";
                        btn.style.boxShadow = "0 10px 20px rgba(46, 204, 113, 0.3)";
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        alert('Ошибка: ' + data.error);
                        btn.disabled = false;
                        btn.innerHTML = originalBtnText;
                    }
                } catch (e) { 
                    alert('Ошибка сети. Проверьте подключение.'); 
                    btn.disabled = false;
                    btn.innerHTML = originalBtnText;
                }
            });
        }
    </script>
</body>
</html>