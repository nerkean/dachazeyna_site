<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('partials/head', { title: 'Зал Славы | Дача Зейна' }) %>
    <link rel="preload" href="/css/leaderboard.css" as="style">
    <link rel="stylesheet" href="/css/leaderboard.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="lb-page">
        <div class="lb-bg-grid"></div>
        <div class="lb-glow"></div>

        <section class="lb-container lb-fade-in">
            <div class="lb-header">
                <div class="lb-season-badge">
                    <span class="live-dot"></span> Сезон 1
                </div>
                <h1 class="lb-title">Зал Славы</h1>
                <p class="lb-subtitle">Выбирай категорию, находи себя в топе и соревнуйся с лучшими!</p>
            </div>

            <div class="lb-tabs">
                <button class="lb-tab active" data-sort="stars"><i class="fas fa-coins"></i> Топ богачей</button>
                <button class="lb-tab" data-sort="messages"><i class="fas fa-comment-dots"></i> Топ писателей</button>
                <button class="lb-tab" data-sort="voice"><i class="fas fa-microphone"></i> Топ говорунов</button>
            </div>

            <div class="lb-periods" id="lb-periods" style="display: none;">
                <button class="lb-period-btn active" data-period="all">Всё время</button>
                <button class="lb-period-btn" data-period="30d">30 дней</button>
                <button class="lb-period-btn" data-period="7d">7 дней</button>
                <button class="lb-period-btn" data-period="1d">24 часа</button>
            </div>

            <div class="lb-podium" id="lb-podium"></div>

            <div class="lb-board">
                <div class="lb-controls">
                    <div class="lb-status"><i class="fas fa-sync-alt fa-spin"></i> Загрузка...</div>
                    <div class="lb-search-box">
                        <i class="fas fa-search"></i>
                        <input type="text" id="lb-search" placeholder="Глобальный поиск по серверу...">
                    </div>
                </div>

                <div class="lb-list-header">
                    <div class="col-rank">Место</div>
                    <div class="col-user">Пчеловод</div>
                    <div class="col-value" id="col-value-title">Капитал</div>
                </div>

                <div class="lb-list-body" id="lb-table-body"></div>
                
                <div class="lb-pagination">
                    <button id="btn-prev" class="lb-btn" disabled><i class="fas fa-chevron-left"></i></button>
                    <div class="lb-page-jump">
                        <span>Стр.</span>
                        <input type="number" id="page-input" value="1" min="1">
                        <span id="page-total">из 1</span>
                    </div>
                    <button id="btn-next" class="lb-btn" disabled><i class="fas fa-chevron-right"></i></button>
                </div>
            </div>
        </section>
    </main>

    <%- include('partials/footer') %>

    <script src="/libs/aos.js" defer></script> 
    <script src="/js/leaderboard.js" defer nonce="<%= locals.nonce %>"></script>
</body>
</html>