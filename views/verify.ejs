<!DOCTYPE html>
<html lang="ru">
<head>
    <%- include('partials/head', { title: 'Верификация | Дача Зейна' }) %>

        <link rel="preload" href="/css/verify.css" as="style">
    <link rel="stylesheet" href="/css/verify.css">
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="verify-section">
        <div class="verify-glass-card">
            <div class="verify-icon-wrapper">
                <i class="fa-solid fa-fingerprint"></i>
            </div>
            
            <h1 class="verify-title">Проверка доступа</h1>
            <p class="verify-desc">Для получения прав участника сервера нам необходимо подтвердить ваш профиль Discord. Это быстрая и безопасная процедура.</p>
            
            <div class="requirements-box">
                <div class="requirements-title">
                    <i class="fa-solid fa-circle-exclamation"></i> Требования для прохождения:
                </div>
                <ul class="requirements-list">
                    <li>
                        <i class="fa-solid fa-envelope-circle-check"></i> 
                        <span>Подтвержденная почта или телефон в Discord</span>
                    </li>
                    <li>
                        <i class="fa-solid fa-calendar-days"></i> 
                        <span>Возраст аккаунта старше 7 дней</span>
                    </li>
                    <li>
                        <i class="fa-solid fa-network-wired"></i> 
                        <span>Отключенный VPN или Proxy-сервер</span>
                    </li>
                </ul>
            </div>
            
            <div class="features-grid">
                <div class="feature-item">
                    <i class="fa-solid fa-users-viewfinder"></i>
                    <span>Блокировка твинков</span>
                </div>
                <div class="feature-item">
                    <i class="fa-solid fa-comments"></i>
                    <span>Все чаты сервера</span>
                </div>
            </div>

            <label class="custom-checkbox-wrapper">
                <input type="checkbox" id="termsCheckbox" class="custom-checkbox">
                <span class="checkbox-text">
                    Я согласен с <a href="/terms" target="_blank">Условиями использования</a> и <a href="/privacy" target="_blank">Политикой конфиденциальности</a>, а также разрешаю обработку моего IP-адреса для защиты сервера
                </span>
            </label>

            <button id="loginBtn" class="btn-discord" disabled onclick="window.location.href='/auth/discord'">
                <i class="fa-brands fa-discord"></i> Авторизоваться
            </button>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script nonce="<%= nonce %>">
        document.addEventListener("DOMContentLoaded", () => {
            if (window.Modal) window.Modal.init();

            const checkbox = document.getElementById('termsCheckbox');
            const loginBtn = document.getElementById('loginBtn');

            checkbox.addEventListener('change', function() {
                if (this.checked) {
                    loginBtn.removeAttribute('disabled');
                } else {
                    loginBtn.setAttribute('disabled', 'true');
                }
            });

            const urlParams = new URLSearchParams(window.location.search);
            const error = urlParams.get('error');
            
            if (error && window.Modal) {
                let errorMessage = "Произошла неизвестная ошибка при авторизации.";
                if (error === 'vpn_blocked') errorMessage = "Обнаружено использование VPN или Proxy. Пожалуйста, отключите его для прохождения верификации.";
                else if (error === 'banned_alt') errorMessage = "Верификация отклонена. Ваш IP-адрес связан с заблокированным аккаунтом на нашем сервере.";
                else if (error === 'account_too_new') errorMessage = "Ваш дискорд-аккаунт был создан слишком недавно. Для безопасности сервера мы принимаем аккаунты старше 7 дней. Попробуйте позже";
                else if (error === 'discord_limit') errorMessage = "Слишком много запросов к Discord. Попробуйте позже.";
                else if (error === 'auth_failed') errorMessage = "Ошибка авторизации Discord. Попробуйте снова.";
                
                window.Modal.alert('Ошибка доступа', errorMessage, 'error');
                window.history.replaceState({}, document.title, window.location.pathname);
            }
        });
    </script>
</body>
</html>